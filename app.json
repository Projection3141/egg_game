{
  "expo": {
    "name": "egg-tap-game",
    "slug": "egg-tap-game",
    "version": "1.0.0",
    "entryPoint": "./App.js",
    "orientation": "portrait",
    "icon": "./assets/egg.png",
    "scheme": "eggtapgame",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "xyz.tailorchain.egg-tap-game",
      "icon": "./assets/egg.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/egg.png",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/egg.png",
        "backgroundImage": "./assets/egg.png",
        "monochromeImage": "./assets/egg.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "xyz.tailorchain.eggtapgame2"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/egg.png"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "b7b5313f-9eec-43a7-8398-2f6316f08672"
      }
    }
  }
}
